DISABLE_ROOT_SSH="${DISABLE_ROOT_SSH:-no}"

CREATE_EXTRA_USER="${CREATE_EXTRA_USER:-yes}"
EXTRA_USER_NAME="${EXTRA_USER_NAME:-core}"
EXTRA_USER_GROUPS="${EXTRA_USER_GROUPS:-wheel}"
EXTRA_USER_SUDO_NOPASSWD="${EXTRA_USER_SUDO_NOPASSWD:-yes}"

ROOT_PASSWORD="${ROOT_PASSWORD:-growin}"
EXTRA_USER_PASSWORD="${EXTRA_USER_PASSWORD:-growin}"

ENABLE_OC_AUTO_LOGIN="${ENABLE_OC_AUTO_LOGIN:-yes}"
OC_LOGIN_USER="${OC_LOGIN_USER:-admin}"
OC_LOGIN_PASSWORD="${OC_LOGIN_PASSWORD:-growin}"
OC_LOGIN_SERVER="${OC_LOGIN_SERVER:-https://api.test.okd:6443}"
