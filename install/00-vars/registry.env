REGISTRY_CONTAINER_PORT="${REGISTRY_CONTAINER_PORT:-5000}"
BASE_REGISTRY_IMAGE="${BASE_REGISTRY_IMAGE:-docker.io/library/registry}"

CERT_DIR="${CERT_DIR:-./certs}"
CERT_FILE="${CERT_FILE:-domain.crt}"
KEY_FILE="${KEY_FILE:-domain.key}"

# skip or replace
CERT_IF_EXISTS="skip"
#CERT_IF_EXISTS="replace"

REGISTRY_TAR_FILE="${REGISTRY_TAR_FILE:-./docker.io_library_registry_2.8.1.tar}"
REGISTRY_TAG="${REGISTRY_TAG:-2.8.1}"

# format: NAME|DIR|HOST_PORT,NAME|DIR|HOST_PORT
REGISTRIES_CSV="${REGISTRIES_CSV:-infra_registry|/NFS/infra_registry|5000,cnf_registry|/NFS/cnf_registry|5001}"
