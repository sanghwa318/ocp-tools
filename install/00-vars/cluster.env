DOMAIN="${DOMAIN:-com}"

NAME="${NAME:-${CLUSTER}.${DOMAIN}}"
CLUSTER_NAME="${CLUSTER_NAME:-${CLUSTER}}"
BASE_DOMAIN="${BASE_DOMAIN:-${NAME}}"

API_SERVER="${API_SERVER:-https://api.${NAME}:6443}"
BASTION_HOST_PATTERN="${BASTION_HOST_PATTERN:-bastion}"
