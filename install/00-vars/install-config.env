INSTALL_BASE_DIR="${INSTALL_BASE_DIR:-/root/growin}"
INSTALL_WORKDIR="${INSTALL_WORKDIR:-${INSTALL_BASE_DIR}/install_$(date +%Y%m%d)}"

SOURCE_INSTALL_CONFIG_FILE="${SOURCE_INSTALL_CONFIG_FILE:-${INSTALL_BASE_DIR}/install-config.yaml}"
INSTALL_CONFIG_FILE="${INSTALL_CONFIG_FILE:-${INSTALL_WORKDIR}/install-config.yaml}"

OPENSHIFT_INSTALL_BIN="${OPENSHIFT_INSTALL_BIN:-/usr/local/bin/openshift-install}"

PULL_SECRET_FILE="${PULL_SECRET_FILE:-/root/pull-secret.json}"
SSH_PUBKEY_FILE="${SSH_PUBKEY_FILE:-/root/.ssh/id_rsa.pub}"
ADDITIONAL_TRUST_BUNDLE_FILE="${ADDITIONAL_TRUST_BUNDLE_FILE:-/root/additional-trust-bundle.pem}"

REGISTRY_HOSTNAME="${REGISTRY_HOSTNAME:-bastion}"

CONTROL_PLANE_REPLICAS="${CONTROL_PLANE_REPLICAS:-1}"
COMPUTE_REPLICAS="${COMPUTE_REPLICAS:-0}"

CLUSTER_NETWORK_CIDR="${CLUSTER_NETWORK_CIDR:-128.0.0.0/8}"
CLUSTER_NETWORK_HOST_PREFIX="${CLUSTER_NETWORK_HOST_PREFIX:-23}"
SERVICE_NETWORK_CIDR="${SERVICE_NETWORK_CIDR:-172.21.0.0/16}"

INSTALL_PLATFORM="${INSTALL_PLATFORM:-none}"
NETWORK_TYPE="${NETWORK_TYPE:-OVNKubernetes}"

IMAGE_MIRROR_HOST="${IMAGE_MIRROR_HOST:-${REGISTRY_HOSTNAME}.${CLUSTER_NAME}.${BASE_DOMAIN}:5000}"
IMAGE_MIRROR_PATH="${IMAGE_MIRROR_PATH:-ocp4/openshift4}"
IMAGE_SOURCE_RELEASE="${IMAGE_SOURCE_RELEASE:-quay.io/okd/scos-release}"
IMAGE_SOURCE_CONTENT="${IMAGE_SOURCE_CONTENT:-quay.io/okd/scos-content}"

COS_SOURCE_DIR="${COS_SOURCE_DIR:-${PWD}/cos}"
COS_KERNEL_MATCH="${COS_KERNEL_MATCH:-kernel}"
COS_INITRAMFS_MATCH="${COS_INITRAMFS_MATCH:-initramfs}"
COS_ROOTFS_MATCH="${COS_ROOTFS_MATCH:-rootfs}"
